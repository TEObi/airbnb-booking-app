// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Account model
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// User model
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  hashedPassword  String?
  role            String    @default("guest") // "guest" or "host"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  properties      Property[]
  bookings        Booking[]
  reviews         Review[]
  favorites       Favorite[]

  @@index([email])
  @@index([role])
}

// Property model
model Property {
  id              String    @id @default(cuid())
  title           String
  description     String    @db.Text
  price           Float
  location        String
  lat             Float
  lng             Float
  category        String
  guestCount      Int
  roomCount       Int
  bathroomCount   Int
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images          PropertyImage[]
  amenities       Amenity[]
  bookings        Booking[]
  reviews         Review[]
  favorites       Favorite[]

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([lat, lng])
}

// PropertyImage model
model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// Amenity model
model Amenity {
  id          String   @id @default(cuid())
  name        String
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// Booking model
model Booking {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  startDate   DateTime
  endDate     DateTime
  totalPrice  Float
  status      String   @default("pending") // "pending", "confirmed", "cancelled"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@unique([userId, propertyId, startDate, endDate])
}

// Review model
model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5 rating scale
  comment     String   @db.Text
  userId      String
  propertyId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([rating])
  @@unique([userId, propertyId])
}

// Favorite model
model Favorite {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}
